    "tags": ["auth", "registration", "free"],
    "license_required": false,
    "license": "MIT",
    "compatibility": {
        "php": "^8.2",
        "tallcms": "^4.3.2"
    },
    "requires_packages": {
        "tallcms/filament-registration": "^1.0"
    }
